<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>2D Platformer</title>
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #0f172a;
      color: #e2e8f0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    .container {
      width: min(100%, 960px);
      padding: 1rem;
      text-align: center;
    }
    canvas {
      width: 100%;
      max-width: 900px;
      background: #020617;
      border: 4px solid #334155;
      border-radius: 16px;
      display: block;
      margin: 0 auto;
    }
    .info {
      margin-top: 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: center;
      font-size: 0.95rem;
      color: #cbd5e1;
    }
    .button {
      border: none;
      padding: 0.75rem 1.1rem;
      border-radius: 9999px;
      background: #2563eb;
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.15s ease, background 0.15s ease;
    }
    .button:hover {
      transform: translateY(-1px);
      background: #1d4ed8;
    }
    .footer {
      margin-top: 0.75rem;
      color: #94a3b8;
    }
  </style>
</head>
<body>
  <div class="container">
    <canvas id="game" width="900" height="500"></canvas>
    <div class="info">
      <button id="restart" class="button">Restart</button>
      <div>Use arrow keys or WASD to move. Jump to the green goal.</div>
      <div>Level <strong id="levelLabel">1</strong> / 3</div>
      <div id="message">Good luck!</div>
    </div>
    <div class="footer">Created by Griffin Ashford</div>
  </div>
  <script>
    const canvas = document.getElementById('game');
    const ctx = canvas.getContext('2d');
    const messageEl = document.getElementById('message');
    const levelLabel = document.getElementById('levelLabel');
    const restartButton = document.getElementById('restart');
    const keys = {};

    const levels = [
      {
        start: { x: 40, y: 380 },
        platforms: [
          { x: 0, y: 456, w: 900, h: 44 },
          { x: 120, y: 360, w: 200, h: 20 },
          { x: 380, y: 300, w: 180, h: 20 },
          { x: 620, y: 240, w: 220, h: 20 },
          { x: 520, y: 180, w: 120, h: 20 },
          { x: 220, y: 120, w: 140, h: 20 }
        ],
        goal: { x: 830, y: 100, w: 40, h: 40 }
      },
      {
        start: { x: 40, y: 380 },
        platforms: [
          { x: 0, y: 456, w: 900, h: 44 },
          { x: 80, y: 360, w: 120, h: 20 },
          { x: 240, y: 300, w: 120, h: 20 },
          { x: 420, y: 240, w: 120, h: 20 },
          { x: 600, y: 180, w: 120, h: 20 },
          { x: 720, y: 120, w: 120, h: 20 }
        ],
        goal: { x: 850, y: 70, w: 40, h: 40 }
      },
      {
        start: { x: 40, y: 380 },
        platforms: [
          { x: 0, y: 456, w: 900, h: 44 },
          { x: 180, y: 380, w: 120, h: 20 },
          { x: 360, y: 320, w: 160, h: 20 },
          { x: 560, y: 260, w: 120, h: 20 },
          { x: 700, y: 200, w: 140, h: 20 },
          { x: 520, y: 120, w: 120, h: 20 }
        ],
        goal: { x: 820, y: 80, w: 40, h: 40 }
      }
    ];

    const gravity = 0.7;
    let currentLevel = 0;
    let level = cloneLevel(currentLevel);
    let player = createPlayer(level.start);
    let won = false;

    function createPlayer(start) {
      return { x: start.x, y: start.y, w: 36, h: 48, dx: 0, dy: 0, onGround: false };
    }

    function cloneLevel(index) {
      const source = levels[index];
      return {
        gravity,
        platforms: source.platforms.map(platform => ({ ...platform })),
        goal: { ...source.goal },
        start: { ...source.start }
      };
    }

    function rectIntersect(a, b) {
      return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y;
    }

    function update() {
      if (won) return;

      const moveLeft = keys.ArrowLeft || keys.KeyA;
      const moveRight = keys.ArrowRight || keys.KeyD;
      const jump = keys.ArrowUp || keys.KeyW || keys.Space;

      if (moveLeft) player.dx -= 0.45;
      if (moveRight) player.dx += 0.45;
      player.dx *= 0.82;
      if (Math.abs(player.dx) < 0.05) player.dx = 0;

      if (jump && player.onGround) {
        player.dy = -13.5;
        player.onGround = false;
      }

      player.dy += level.gravity;
      player.x += player.dx;
      player.y += player.dy;
      player.onGround = false;

      const bounds = { x: player.x, y: player.y, w: player.w, h: player.h };
      for (const platform of level.platforms) {
        const platformRect = { x: platform.x, y: platform.y, w: platform.w, h: platform.h };
        if (rectIntersect(bounds, platformRect)) {
          const overlapX = Math.min(player.x + player.w - platform.x, platform.x + platform.w - player.x);
          const overlapY = Math.min(player.y + player.h - platform.y, platform.y + platform.h - player.y);
          if (overlapY < overlapX) {
            if (player.dy > 0) {
              player.y = platform.y - player.h;
              player.dy = 0;
              player.onGround = true;
            } else {
              player.y = platform.y + platform.h;
              player.dy = 0;
            }
          } else {
            if (player.dx > 0) {
              player.x = platform.x - player.w;
            } else if (player.dx < 0) {
              player.x = platform.x + platform.w;
            }
            player.dx = 0;
          }
        }
      }

      if (player.y > canvas.height) {
        reset('Fell off the stage!');
        return;
      }

      if (player.x < 0) player.x = 0;
      if (player.x + player.w > canvas.width) player.x = canvas.width - player.w;

      if (rectIntersect(player, level.goal)) {
        won = true;
        if (currentLevel + 1 < levels.length) {
          messageEl.textContent = 'Level complete! Loading next level...';
          setTimeout(() => {
            currentLevel += 1;
            loadLevel(currentLevel);
          }, 1000);
        } else {
          messageEl.textContent = 'You beat the game! Great work!';
        }
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#020617';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.fillStyle = '#334155';
      for (const platform of level.platforms) {
        ctx.fillRect(platform.x, platform.y, platform.w, platform.h);
      }

      ctx.fillStyle = '#16a34a';
      ctx.fillRect(level.goal.x, level.goal.y, level.goal.w, level.goal.h);

      ctx.fillStyle = '#f8fafc';
      ctx.fillRect(player.x, player.y, player.w, player.h);

      ctx.strokeStyle = '#94a3b8';
      ctx.lineWidth = 3;
      ctx.strokeRect(0, 0, canvas.width, canvas.height);
    }

    function loop() {
      update();
      draw();
      requestAnimationFrame(loop);
    }

    function loadLevel(index) {
      level = cloneLevel(index);
      player = createPlayer(level.start);
      won = false;
      levelLabel.textContent = index + 1;
      messageEl.textContent = `Level ${index + 1} — reach the green goal!`;
    }

    function reset(message = 'Ready when you are!') {
      player = createPlayer(level.start);
      won = false;
      messageEl.textContent = message;
    }

    window.addEventListener('keydown', event => {
      keys[event.code] = true;
    });

    window.addEventListener('keyup', event => {
      keys[event.code] = false;
    });

    restartButton.addEventListener('click', () => reset('Restarted the level.'));
    loadLevel(currentLevel);
    requestAnimationFrame(loop);
  </script>
</body>
</html>
